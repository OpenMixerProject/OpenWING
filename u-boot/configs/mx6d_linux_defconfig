CONFIG_ARM=y
CONFIG_ARCH_MX6=y
CONFIG_TEXT_BASE=0x17800000
CONFIG_SYS_MALLOC_LEN=0xa00000
CONFIG_SYS_MALLOC_F_LEN=0x4000
CONFIG_NR_DRAM_BANKS=1
CONFIG_SF_DEFAULT_SPEED=25000000
CONFIG_ENV_SIZE=0x2000
CONFIG_ENV_OFFSET=0xC0000
CONFIG_IMX_CONFIG="board/boundary/nitrogen6x/nitrogen6s1g.cfg"
CONFIG_MX6S=y
CONFIG_TARGET_NITROGEN6X=y
# CONFIG_SYS_I2C_MXC_I2C1 is not set
# CONFIG_SYS_I2C_MXC_I2C2 is not set
# CONFIG_SYS_I2C_MXC_I2C3 is not set
CONFIG_DDR_MB=1024
CONFIG_DM_GPIO=y
CONFIG_DEFAULT_DEVICE_TREE="imx6dl-nitrogen6x"

# Auto-boot the embedded Linux FIT image.  The wingfw packager places
# U-Boot at APPADDR + 0x5000 = 0x10009000 (768 KiB reserved) and the FIT
# image immediately after at APPADDR + 0xC5000 = 0x100C9000.
CONFIG_BOOTDELAY=5
CONFIG_USE_BOOTCOMMAND=y
CONFIG_BOOTCOMMAND="echo WING_DIAG: autobooting Linux in diagnostic mode; setenv bootargs console=tty1 console=ttyGS0,115200 console=ttymxc1,115200 earlycon ignore_loglevel loglevel=8 initcall_debug g_serial.use_acm=1 root=/dev/ram0 rdinit=/init rw; printenv bootargs; iminfo 0x100C9000; bootm 0x100C9000"
CONFIG_AUTOBOOT_KEYED=n

CONFIG_CONSOLE_MUX=y
CONFIG_SYS_CONSOLE_IS_IN_ENV=y
CONFIG_SYS_CONSOLE_OVERWRITE_ROUTINE=y
CONFIG_BOARD_EARLY_INIT_F=y
CONFIG_HUSH_PARSER=y
CONFIG_SYS_MAXARGS=32
CONFIG_SYS_PBSIZE=532

CONFIG_CMD_MEMORY=y
# CONFIG_CMD_FLASH is not set
CONFIG_CMD_GPIO=y
CONFIG_CMD_MMC=y
CONFIG_CMD_USB=y
CONFIG_CMD_USB_MASS_STORAGE=y
CONFIG_CMD_CACHE=y
CONFIG_CMD_EXT2=y
CONFIG_CMD_EXT4=y
CONFIG_CMD_FAT=y
CONFIG_CMD_FS_GENERIC=y

# Linux boot plumbing.
CONFIG_FIT=y
CONFIG_FIT_VERBOSE=y
CONFIG_LEGACY_IMAGE_FORMAT=y
CONFIG_BOOTM_LINUX=y
CONFIG_SUPPORT_RAW_INITRD=y
CONFIG_OF_LIBFDT=y
CONFIG_LZ4=y
CONFIG_GZIP=y

CONFIG_OF_CONTROL=y
CONFIG_ENV_OVERWRITE=y
CONFIG_ENV_IS_NOWHERE=y
CONFIG_SYS_RELOC_GD_ENV_ADDR=y
CONFIG_BOUNCE_BUFFER=y
CONFIG_FSL_USDHC=y
CONFIG_PINCTRL=y
CONFIG_PINCTRL_IMX6=y
CONFIG_MXC_UART=y
CONFIG_DM_THERMAL=y

# USB ACM gadget kept enabled for early-boot debug, but the bootcmd
# above will hand off to Linux automatically before the user typically
# notices the U-Boot prompt.
CONFIG_USB=y
CONFIG_USB_GADGET=y
CONFIG_USB_GADGET_MANUFACTURER="FSL"
CONFIG_USB_GADGET_VENDOR_NUM=0x0525
CONFIG_USB_GADGET_PRODUCT_NUM=0xa4a5
CONFIG_CI_UDC=y
CONFIG_USB_GADGET_DOWNLOAD=y
CONFIG_USB_FUNCTION_ACM=y

CONFIG_CMD_SF=y
CONFIG_SPI=y
CONFIG_MXC_SPI=y
CONFIG_MTD=y
CONFIG_DM_SPI=y
CONFIG_DM_SPI_FLASH=y
CONFIG_SPI_FLASH_STMICRO=y
CONFIG_SPI_FLASH_WINBOND=y
CONFIG_SPI_FLASH_MACRONIX=y
# CONFIG_VIDEO is not set
